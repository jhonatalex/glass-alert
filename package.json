{
  "name": "glass-alert-animation",
  "version": "0.1.6",
  "description": "A beautiful glassmorphism alert/modal library with GSAP animations for React. Premium liquid glass style popups with animated icons, backgrounds, and smooth transitions.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/glass-alert.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "vite demo",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "alert",
    "modal",
    "glassmorphism",
    "glass",
    "popup",
    "dialog",
    "confirm",
    "notification",
    "gsap",
    "animation",
    "react",
    "sweetalert",
    "toast",
    "liquid-glass"
  ],
  "author": "jhonatalex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jhonatalex/glass-alert.git"
  },
  "peerDependencies": {
    "gsap": ">=3.12.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "gsap": {
      "optional": false
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "gsap": "^3.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-postcss": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "lottie-react": "^2.4.1"
  }
}